generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model asset_assignments {
  assignment_id                              Int                                  @id @default(autoincrement())
  asset_id                                   Int
  user_id                                    Int
  assigned_by                                Int?
  assigned_date                              DateTime                             @db.Date
  return_date                                DateTime?                            @db.Date
  assignment_status                          asset_assignments_assignment_status? @default(Assigned)
  remarks                                    String?                              @db.Text
  users_asset_assignments_assigned_byTousers users?                               @relation("asset_assignments_assigned_byTousers", fields: [assigned_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assignment_admin")
  assets                                     assets                               @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assignment_asset")
  users_asset_assignments_user_idTousers     users                                @relation("asset_assignments_user_idTousers", fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_assignment_user")

  @@index([assigned_by], map: "fk_assignment_admin")
  @@index([asset_id], map: "fk_assignment_asset")
  @@index([user_id], map: "fk_assignment_user")
}

model assets {
  asset_id             Int                     @id @default(autoincrement())
  asset_tag            String                  @unique(map: "asset_tag") @db.VarChar(50)
  asset_name           String                  @db.VarChar(100)
  category_id          Int
  vendor_id            Int?
  serial_number        String?                 @unique(map: "serial_number") @db.VarChar(100)
  purchase_date        DateTime?               @db.Date
  purchase_price       Decimal?                @db.Decimal(10, 2)
  warranty_end         DateTime?               @db.Date
  location             String?                 @db.VarChar(100)
  asset_status         assets_asset_status?    @default(Available)
  asset_condition      assets_asset_condition? @default(Good)
  created_at           DateTime?               @default(now()) @db.Timestamp(0)
  asset_assignments    asset_assignments[]
  categories           categories              @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_category")
  vendors              vendors?                @relation(fields: [vendor_id], references: [vendor_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_vendor")
  maintenance_requests maintenance_requests[]

  @@index([category_id], map: "fk_asset_category")
  @@index([vendor_id], map: "fk_asset_vendor")
}

model audit_logs {
  log_id      Int       @id @default(autoincrement())
  user_id     Int?
  action      String    @db.VarChar(100)
  module      String    @db.VarChar(100)
  description String?   @db.Text
  ip_address  String?   @db.VarChar(45)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  users       users?    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_user")

  @@index([user_id], map: "fk_audit_user")
}

model categories {
  category_id          Int                    @id @default(autoincrement())
  category_name        String                 @unique(map: "category_name") @db.VarChar(100)
  description          String?                @db.Text
  created_at           DateTime?              @default(now()) @db.Timestamp(0)
  assets               assets[]
  procurement_requests procurement_requests[]
}

model departments {
  department_id   Int       @id @default(autoincrement())
  department_name String    @unique(map: "department_name") @db.VarChar(100)
  description     String?   @db.Text
  created_at      DateTime? @default(now()) @db.Timestamp(0)
}

model maintenance_requests {
  maintenance_id    Int                            @id @default(autoincrement())
  asset_id          Int
  reported_by       Int
  issue_title       String                         @db.VarChar(150)
  issue_description String?                        @db.Text
  priority          maintenance_requests_priority? @default(Medium)
  status            maintenance_requests_status?   @default(Pending)
  technician_name   String?                        @db.VarChar(100)
  cost              Decimal?                       @db.Decimal(10, 2)
  reported_date     DateTime?                      @default(now()) @db.Timestamp(0)
  completed_date    DateTime?                      @db.Timestamp(0)
  assets            assets                         @relation(fields: [asset_id], references: [asset_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_maintenance_asset")
  users             users                          @relation(fields: [reported_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_maintenance_user")

  @@index([asset_id], map: "fk_maintenance_asset")
  @@index([reported_by], map: "fk_maintenance_user")
}

model notifications {
  notification_id   Int                              @id @default(autoincrement())
  user_id           Int
  title             String                           @db.VarChar(150)
  message           String                           @db.Text
  notification_type notifications_notification_type? @default(Info)
  is_read           Boolean?                         @default(false)
  created_at        DateTime?                        @default(now()) @db.Timestamp(0)
  users             users                            @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notification_user")

  @@index([user_id], map: "fk_notification_user")
}

model procurement_requests {
  request_id                                     Int                          @id @default(autoincrement())
  requested_by                                   Int
  asset_name                                     String                       @db.VarChar(100)
  category_id                                    Int
  quantity                                       Int                          @default(1)
  estimated_price                                Decimal?                     @db.Decimal(10, 2)
  justification                                  String?                      @db.Text
  status                                         procurement_requests_status? @default(Pending)
  request_date                                   DateTime?                    @default(now()) @db.Timestamp(0)
  approved_by                                    Int?
  approval_date                                  DateTime?                    @db.Timestamp(0)
  users_procurement_requests_approved_byTousers  users?                       @relation("procurement_requests_approved_byTousers", fields: [approved_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_procurement_approver")
  categories                                     categories                   @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_procurement_category")
  users_procurement_requests_requested_byTousers users                        @relation("procurement_requests_requested_byTousers", fields: [requested_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_procurement_user")

  @@index([approved_by], map: "fk_procurement_approver")
  @@index([category_id], map: "fk_procurement_category")
  @@index([requested_by], map: "fk_procurement_user")
}

model users {
  user_id                                                       Int                    @id @default(autoincrement())
  full_name                                                     String                 @db.VarChar(100)
  email                                                         String                 @unique(map: "email") @db.VarChar(100)
  password                                                      String                 @db.VarChar(255)
  role                                                          users_role
  department                                                    String?                @db.VarChar(100)
  created_at                                                    DateTime?              @default(now()) @db.Timestamp(0)
  asset_assignments_asset_assignments_assigned_byTousers        asset_assignments[]    @relation("asset_assignments_assigned_byTousers")
  asset_assignments_asset_assignments_user_idTousers            asset_assignments[]    @relation("asset_assignments_user_idTousers")
  audit_logs                                                    audit_logs[]
  maintenance_requests                                          maintenance_requests[]
  notifications                                                 notifications[]
  procurement_requests_procurement_requests_approved_byTousers  procurement_requests[] @relation("procurement_requests_approved_byTousers")
  procurement_requests_procurement_requests_requested_byTousers procurement_requests[] @relation("procurement_requests_requested_byTousers")
}

model vendors {
  vendor_id      Int       @id @default(autoincrement())
  vendor_name    String    @db.VarChar(100)
  contact_person String?   @db.VarChar(100)
  email          String?   @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  address        String?   @db.Text
  city           String?   @db.VarChar(100)
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  assets         assets[]
}

enum notifications_notification_type {
  Info
  Success
  Warning
  Error
}

enum users_role {
  Admin
  Manager
  Employee
}

enum maintenance_requests_priority {
  Low
  Medium
  High
}

enum asset_assignments_assignment_status {
  Assigned
  Returned
}

enum maintenance_requests_status {
  Pending
  In_Progress @map("In Progress")
  Completed
  Cancelled
}

enum procurement_requests_status {
  Pending
  Approved
  Rejected
  Ordered
  Received
}

enum assets_asset_status {
  Available
  Assigned
  Maintenance
  Retired
}

enum assets_asset_condition {
  Excellent
  Good
  Fair
  Poor
}
