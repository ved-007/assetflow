generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditItemResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  passwordHash         String
  departmentId         Int?
  role                 Role      @default(EMPLOYEE)
  status               String    @default("ACTIVE") // Just a generic string status or boolean? Using string.
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  department           Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  headedDepartments    Department[] @relation("DepartmentHead")

  allocations          Allocation[] @relation("EmployeeAllocations")
  transfersFrom        TransferRequest[] @relation("TransferFrom")
  transfersTo          TransferRequest[] @relation("TransferTo")
  transfersApproved    TransferRequest[] @relation("TransferApprover")
  bookings             Booking[] @relation("Bookings")
  maintenanceRaised    MaintenanceRequest[] @relation("MaintenanceRaiser")
  maintenanceApproved  MaintenanceRequest[] @relation("MaintenanceApprover")
  auditCyclesCreated   AuditCycle[] @relation("AuditCycleCreator")
  auditAssignments     AuditAssignment[] @relation("Auditor")
  auditItemsChecked    AuditItem[] @relation("AuditItemChecker")
  notifications        Notification[] @relation("UserNotifications")
  activityLogs         ActivityLog[] @relation("ActivityActor")

  @@map("users")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  headId      Int?
  parentId    Int?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  head        User?       @relation("DepartmentHead", fields: [headId], references: [id])
  parent      Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  members     User[]      @relation("DepartmentMembers")
  allocations Allocation[] @relation("DepartmentAllocations")
  auditCycles AuditCycle[] @relation("DepartmentAudits")

  @@map("departments")
}

model AssetCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  customFields Json?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assets       Asset[]

  @@map("asset_categories")
}

model Asset {
  id              Int         @id @default(autoincrement())
  assetTag        String      @unique
  name            String
  categoryId      Int
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Float?
  condition       String?
  location        String?
  photoUrl        String?
  isBookable      Boolean     @default(false)
  status          AssetStatus @default(AVAILABLE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category        AssetCategory @relation(fields: [categoryId], references: [id])
  
  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  @@map("assets")
}

model Allocation {
  id                 Int       @id @default(autoincrement())
  assetId            Int
  employeeId         Int
  departmentId       Int?
  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  checkinCondition   String?
  checkinNotes       String?

  asset      Asset       @relation(fields: [assetId], references: [id])
  employee   User        @relation("EmployeeAllocations", fields: [employeeId], references: [id])
  department Department? @relation("DepartmentAllocations", fields: [departmentId], references: [id])

  @@map("allocations")
}

model TransferRequest {
  id             Int            @id @default(autoincrement())
  assetId        Int
  fromEmployeeId Int
  toEmployeeId   Int
  reason         String
  status         TransferStatus @default(REQUESTED)
  approvedById   Int?
  decidedAt      DateTime?
  createdAt      DateTime       @default(now())

  asset        Asset @relation(fields: [assetId], references: [id])
  fromEmployee User  @relation("TransferFrom", fields: [fromEmployeeId], references: [id])
  toEmployee   User  @relation("TransferTo", fields: [toEmployeeId], references: [id])
  approvedBy   User? @relation("TransferApprover", fields: [approvedById], references: [id])

  @@map("transfer_requests")
}

model Booking {
  id         Int           @id @default(autoincrement())
  assetId    Int
  bookedById Int
  startTime  DateTime
  endTime    DateTime
  purpose    String
  status     BookingStatus @default(UPCOMING)
  createdAt  DateTime      @default(now())

  asset    Asset @relation(fields: [assetId], references: [id])
  bookedBy User  @relation("Bookings", fields: [bookedById], references: [id])

  @@map("bookings")
}

model MaintenanceRequest {
  id             Int                 @id @default(autoincrement())
  assetId        Int
  raisedById     Int
  description    String
  priority       MaintenancePriority @default(MEDIUM)
  photoUrl       String?
  status         MaintenanceStatus   @default(PENDING)
  technicianName String?
  approvedById   Int?
  resolvedAt     DateTime?
  createdAt      DateTime            @default(now())

  asset      Asset @relation(fields: [assetId], references: [id])
  raisedBy   User  @relation("MaintenanceRaiser", fields: [raisedById], references: [id])
  approvedBy User? @relation("MaintenanceApprover", fields: [approvedById], references: [id])

  @@map("maintenance_requests")
}

model AuditCycle {
  id           Int              @id @default(autoincrement())
  name         String
  departmentId Int?
  location     String?
  startDate    DateTime
  endDate      DateTime
  status       AuditCycleStatus @default(OPEN)
  createdById  Int
  createdAt    DateTime         @default(now())

  department  Department?       @relation("DepartmentAudits", fields: [departmentId], references: [id])
  createdBy   User              @relation("AuditCycleCreator", fields: [createdById], references: [id])
  assignments AuditAssignment[]
  items       AuditItem[]

  @@map("audit_cycles")
}

model AuditAssignment {
  id        Int @id @default(autoincrement())
  cycleId   Int
  auditorId Int

  cycle   AuditCycle @relation(fields: [cycleId], references: [id])
  auditor User       @relation("Auditor", fields: [auditorId], references: [id])

  @@map("audit_assignments")
}

model AuditItem {
  id          Int             @id @default(autoincrement())
  cycleId     Int
  assetId     Int
  result      AuditItemResult @default(PENDING)
  notes       String?
  checkedById Int?
  checkedAt   DateTime?

  cycle     AuditCycle @relation(fields: [cycleId], references: [id])
  asset     Asset      @relation(fields: [assetId], references: [id])
  checkedBy User?      @relation("AuditItemChecker", fields: [checkedById], references: [id])

  @@map("audit_items")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id])

  @@map("notifications")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  actorId    Int
  action     String
  entityType String
  entityId   Int
  details    Json?
  createdAt  DateTime @default(now())

  actor User @relation("ActivityActor", fields: [actorId], references: [id])

  @@map("activity_logs")
}
