generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditItemResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

model User {
  id           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  passwordHash String
  departmentId Int?
  role         Role        @default(EMPLOYEE)
  status       String      @default("ACTIVE")
  department   Department? @relation(fields: [departmentId], references: [id])

  allocations          Allocation[]
  transferRequestsFrom TransferRequest[]    @relation("FromEmployee")
  transferRequestsTo   TransferRequest[]    @relation("ToEmployee")
  bookings             Booking[]
  maintenanceRequests  MaintenanceRequest[]
  auditAssignments     AuditAssignment[]
  notifications        Notification[]
  activityLogs         ActivityLog[]

  headOfDepartments  Department[] @relation("DepartmentHead")
  createdAuditCycles AuditCycle[] @relation("AuditCycleCreator")
}

model Department {
  id       Int    @id @default(autoincrement())
  name     String @unique
  headId   Int?
  parentId Int?
  status   String @default("ACTIVE")

  head     User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parent   Department?  @relation("ParentDepartment", fields: [parentId], references: [id])
  children Department[] @relation("ParentDepartment")
  users    User[]

  allocations Allocation[]
  auditCycles AuditCycle[]
}

model AssetCategory {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  customFields Json?
  status       String  @default("ACTIVE")
  assets       Asset[]
}

model Asset {
  id              Int         @id @default(autoincrement())
  assetTag        String      @unique // AF-0001
  name            String
  categoryId      Int
  serialNumber    String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?    @db.Decimal(10, 2)
  condition       String?
  location        String?
  photoUrl        String?
  isBookable      Boolean     @default(false)
  status          AssetStatus @default(AVAILABLE)

  category AssetCategory @relation(fields: [categoryId], references: [id])

  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
}

model Allocation {
  id                 Int       @id @default(autoincrement())
  assetId            Int
  employeeId         Int
  departmentId       Int?
  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  checkinCondition   String?
  checkinNotes       String?

  asset      Asset       @relation(fields: [assetId], references: [id])
  employee   User        @relation(fields: [employeeId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
}

model TransferRequest {
  id             Int            @id @default(autoincrement())
  assetId        Int
  fromEmployeeId Int
  toEmployeeId   Int
  reason         String?        @db.Text
  status         TransferStatus @default(REQUESTED)
  approvedById   Int?
  decidedAt      DateTime?

  asset        Asset @relation(fields: [assetId], references: [id])
  fromEmployee User  @relation("FromEmployee", fields: [fromEmployeeId], references: [id])
  toEmployee   User  @relation("ToEmployee", fields: [toEmployeeId], references: [id])
}

model Booking {
  id         Int           @id @default(autoincrement())
  assetId    Int
  bookedById Int
  startTime  DateTime
  endTime    DateTime
  purpose    String?       @db.Text
  status     BookingStatus @default(UPCOMING)

  asset    Asset @relation(fields: [assetId], references: [id])
  bookedBy User  @relation(fields: [bookedById], references: [id])
}

model MaintenanceRequest {
  id             Int                 @id @default(autoincrement())
  assetId        Int
  raisedById     Int
  description    String              @db.Text
  priority       MaintenancePriority @default(MEDIUM)
  photoUrl       String?
  status         MaintenanceStatus   @default(PENDING)
  technicianName String?
  approvedById   Int?
  resolvedAt     DateTime?

  asset    Asset @relation(fields: [assetId], references: [id])
  raisedBy User  @relation(fields: [raisedById], references: [id])
}

model AuditCycle {
  id           Int              @id @default(autoincrement())
  name         String
  departmentId Int?
  location     String?
  startDate    DateTime
  endDate      DateTime
  status       AuditCycleStatus @default(OPEN)
  createdById  Int

  department Department? @relation(fields: [departmentId], references: [id])
  createdBy  User        @relation("AuditCycleCreator", fields: [createdById], references: [id])

  assignments AuditAssignment[]
  items       AuditItem[]
}

model AuditAssignment {
  id        Int @id @default(autoincrement())
  cycleId   Int
  auditorId Int

  cycle   AuditCycle @relation(fields: [cycleId], references: [id])
  auditor User       @relation(fields: [auditorId], references: [id])
}

model AuditItem {
  id          Int             @id @default(autoincrement())
  cycleId     Int
  assetId     Int
  result      AuditItemResult @default(PENDING)
  notes       String?         @db.Text
  checkedById Int?
  checkedAt   DateTime?

  cycle AuditCycle @relation(fields: [cycleId], references: [id])
  asset Asset      @relation(fields: [assetId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  body      String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  actorId    Int
  action     String
  entityType String
  entityId   Int
  details    Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}
